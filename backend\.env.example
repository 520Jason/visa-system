# 环境配置文件
# 复制为 .env 后使用

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=visa_db

# JWT 密钥
JWT_SECRET_KEY=your_jwt_secret_key_change_this_in_production
JWT_ALGORITHM=HS256

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 文件上传
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
